{"name":"Example activity events output","description":"Use activity events to show progress in front end","nodes":[{"applyInitialization":false,"initializing":{"entries":[],"version":1,"id":"f66a1f94-3438-4b7f-b154-e3abf8958cc6"},"nodeType":0,"title":"Start","top":60,"left":60,"width":80,"height":80,"inputs":[],"outputs":[{"name":"","version":1,"id":"4cea8f96-9ef7-4c36-8077-fd5dc29abc42"}],"version":1,"id":"bbae15aa-3166-45fe-aba9-dfa8b466c3e0"},{"code":"var step1 = new ContextObject();\r\nstep1.Add(\u0022id\u0022, \u0022resolve-location\u0022);\r\nstep1.Add(\u0022label\u0022, \u0022Raising the sails\u0022);\r\nstep1.Add(\u0022state\u0022, \u0022started\u0022);\r\n\r\n\r\nvar step2 = new ContextObject();\r\nContext.Set(\u0022progress\u0022, 0);\r\nstep2.Add(\u0022id\u0022, \u0022fetch-weather\u0022);\r\nstep2.Add(\u0022label\u0022, \u0022Salting the pork\u0022);\r\nstep2.Add(\u0022description\u0022, \u0022Calling the weather provider\u0022);\r\nstep2.Add(\u0022state\u0022, \u00220%\u0022);\r\n\r\nvar steps = new ContextList();\r\nsteps.Add(step1);\r\nsteps.Add(step2);\r\n\r\nvar activity = new ContextObject();\r\nactivity.Add(\u0022title\u0022, \u0022Preparing to sail\u0022);\r\nactivity.Add(\u0022steps\u0022, steps);\r\n\r\nContext.Set(\u0022activity\u0022, activity);\r\n\r\n","nodeType":2,"title":"Code","top":60,"left":220,"width":80,"height":80,"inputs":[{"name":"","version":1,"id":"f51e4389-0b80-4cf3-bf34-5a939654aad4"}],"outputs":[{"name":"","version":1,"id":"fd8d1804-9f44-40ef-8439-2e4fd6cf9e04"}],"version":1,"id":"82730aa1-df39-4647-8728-2ae4541b97ea"},{"instanceName":"example","activityType":"EXAMPLE","contextPath":"activity","initialReplace":false,"snapshotsOnly":false,"nodeType":15,"title":"Activity Sync","top":60,"left":360,"width":80,"height":80,"inputs":[{"name":"","version":1,"id":"00ad9ae9-7b66-4ce6-96df-b7fa9cfb26b8"}],"outputs":[{"name":"","version":1,"id":"8bd71276-8983-48bb-ae07-8a2737db2928"}],"version":1,"id":"9ffff2a1-e6f5-433b-8845-ede5d6db76ec"},{"instanceName":"example","activityType":"EXAMPLE","contextPath":"activity","initialReplace":false,"snapshotsOnly":false,"nodeType":15,"title":"Activity Sync","top":60,"left":640,"width":80,"height":80,"inputs":[{"name":"","version":1,"id":"da15b71f-442c-4459-94e7-09d57845f48f"}],"outputs":[{"name":"","version":1,"id":"2232ebec-1840-4b91-b301-b35d0767bcdc"}],"version":1,"id":"211ccd7c-32ac-493a-b0c1-349d95ff166c"},{"code":"await Task.Delay(2000);\r\nContext.Set(\u0022activity.steps[0].state\u0022, \u0022finished\u0022);\r\n","nodeType":2,"title":"Delay 1","top":60,"left":500,"width":80,"height":80,"inputs":[{"name":"","version":1,"id":"3c2f39c1-d3e3-4ee6-96a0-cc39ee2c0430"}],"outputs":[{"name":"","version":1,"id":"9dea3f5f-f98d-4dc5-8520-218e5c813fee"}],"version":1,"id":"541a3fcd-6fc6-46fc-9cc0-129c54311a25"},{"code":"await Task.Delay(200);\r\nvar progress = Context.Get\u003Cint\u003E(\u0022progress\u0022);\r\nprogress \u002B= 10;\r\nContext.Set(\u0022progress\u0022, progress);\r\nContext.Set(\u0022activity.steps[1].state\u0022, $\u0022{progress}%\u0022);","nodeType":2,"title":"Update %","top":60,"left":780,"width":80,"height":80,"inputs":[{"name":"","version":1,"id":"15cd7a98-c222-4ee7-b5d0-88519395fd81"}],"outputs":[{"name":"","version":1,"id":"a4effdfc-22ad-4976-bf58-f0a2154226a1"}],"version":1,"id":"785b1a0d-ee54-4871-9d2c-278faa6a7693"},{"instanceName":"example","activityType":"EXAMPLE","contextPath":"activity","initialReplace":false,"snapshotsOnly":false,"nodeType":15,"title":"Activity Sync","top":60,"left":920,"width":80,"height":80,"inputs":[{"name":"","version":1,"id":"8c1d1f94-72be-484a-92ad-28d7699b9b3a"}],"outputs":[{"name":"","version":1,"id":"aa37a374-70b9-48c9-97e0-0f4fe4f7918a"}],"version":1,"id":"789af68b-534d-401b-850c-61b6497fbba1"},{"switches":[{"name":"finished","code":"return Context.Get\u003Cint\u003E(\u0022progress\u0022) \u003E= 100;","version":1,"id":"4396b95d-3613-4cb1-841e-ac0c12259c55"},{"name":"loop","code":"","version":1,"id":"eb0